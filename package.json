{
  "name": "pdf-fasi",
  "private": true,
  "version": "0.3.0",
  "description": "Desktop PDF utility focused on local compression",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "dist:win": "npm exec -- electron-builder --win portable --publish never",
    "dist:mac": "npm exec -- electron-builder --mac dmg --publish never"
  },
  "build": {
    "appId": "com.pdf-fasi.app",
    "productName": "PDF-Fasi",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  },
  "devDependencies": {
    "electron-builder": "26.11.1",
    "electron": "*"
  }
}
